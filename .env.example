# Required Supabase environment variables
# Copy this file to .env.local and fill in your values from:
# https://app.supabase.com → Project Settings → API

# Your Supabase project URL (already known from connection string)
NEXT_PUBLIC_SUPABASE_URL=https://gyiejgwvvylxltcoglsk.supabase.co

# Anon / public key — get this from:
# Supabase Dashboard → Settings → API → Project API keys → "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only needed for npm run seed (bypasses RLS)
# Supabase Dashboard → Settings → API → Project API keys → "service_role"
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
